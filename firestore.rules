rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128; }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /teams/{teamId} {
      allow read: if true;
      allow write: if true; // In a real app, restrict to admin. For now, public admin access.
    }

    match /_health/{docId} {
      allow read: if true;
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if true;
    }

    match /presence/{sessionId} {
      allow read, write: if true;
    }
  }
}
